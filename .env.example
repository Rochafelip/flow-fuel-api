# Copie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA comite o arquivo .env no Git (já está no .gitignore).

# Segredo JWT (HS256/HS512), minimo 32 caracteres. Obrigatorio em todos os
# perfis, incluindo dev — a aplicacao nao sobe sem ele. Gere um valor com:
#   openssl rand -base64 32
JWT_SECRET=<gere-com-openssl-rand--base64-32>

# Open Charge Map API key (gratuita — cadastre-se em openchargemap.org e
# gere em openchargemap.org/site/profile/applications). Opcional: sem ela a
# aplicacao sobe normalmente, mas GET /stations/nearby nunca retorna
# estacoes type: ELECTRIC (so postos de combustivel via Overpass).
OPEN_CHARGE_MAP_API_KEY=<sua-key-do-openchargemap>
