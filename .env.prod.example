# Ambiente prod local (docker compose). Copie para .env.prod e ajuste.
#   cp .env.prod.example .env.prod
#   docker compose --env-file .env.prod up --build
# NUNCA commite o .env.prod (adicione ao .gitignore).

# OBRIGATORIO: minimo 32 caracteres. Gere com: openssl rand -hex 32
JWT_SECRET=troque-por-um-segredo-de-32-caracteres-no-minimo

# Senha do Postgres local (qualquer valor; so vale na sua maquina).
POSTGRES_PASSWORD=flowfuel

# Origens permitidas no CORS (seu front local).
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081

# Swagger UI (ligado aqui para facilitar testes manuais).
SWAGGER_ENABLED=true

# --- Email de ativacao de conta (SendGrid via SMTP) ---
# Com MAIL_ENABLED=true o link de ativacao e enviado por email (SmtpAccount
# ActivationNotifier). Com false (ou ausente) o link so aparece no log.
MAIL_ENABLED=false
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
# No SendGrid o usuario e SEMPRE a string literal "apikey"; a senha e a API key.
MAIL_USERNAME=apikey
MAIL_PASSWORD=
# Remetente verificado no SendGrid (Single Sender ou dominio autenticado).
MAIL_FROM=no-reply@flowfuel.app
# Rota do frontend que recebe ?token=... e chama POST /api/v1/auth/activate.
ACCOUNT_ACTIVATION_LINK_BASE_URL=http://localhost:5173/activate
